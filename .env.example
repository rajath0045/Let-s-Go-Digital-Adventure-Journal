# QuestVault Configuration Template

# 1. Supabase Backend Config
# Get these keys from your Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 2. Google OAuth Config for Sheets Export (Optional, can also be input in settings UI)
# Get this from your Google Cloud Console -> APIs & Services -> Credentials
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
